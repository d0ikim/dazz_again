.DS_Store

# Spring Boot local config
application-local.properties
application-local.yml

# 환경변수 파일 (비밀번호 등 민감 정보 — 절대 GitHub에 올리면 안 됨)
.env

# Python 가상환경 (각 개발자 로컬에서만 필요, git에 올리지 않음)
venv/
__pycache__/
*.pyc

# 디자인 참고 자료 (git에 올리지 않음)
design_handoff/
